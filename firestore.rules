rules_version = '2';
// Forced update for deployment retry
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAuthor() {
      return request.auth != null && request.auth.token.email in ['abpublicuser@gmail.com', 'rbalaji70@gmail.com'];
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 3. Entity Validation
    function isValidTripCreate(data) {
      return data.keys().hasAll(['name', 'coverImageUrl', 'userId', 'userName', 'userEmail', 'createdAt'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() <= 100
        && data.coverImageUrl is string && data.coverImageUrl.size() <= 1045000
        && data.userId is string && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 100
        && data.userEmail is string && data.userEmail.size() <= 100
        && data.createdAt == request.time;
    }

    function isValidTripUpdate(data) {
      return data.keys().hasAll(['name', 'coverImageUrl', 'userId', 'userName', 'userEmail', 'createdAt'])
        && data.name is string && data.name.size() <= 100
        && data.coverImageUrl is string && data.coverImageUrl.size() <= 10485760
        && data.userId == existing().userId
        && data.userName == existing().userName
        && data.userEmail == existing().userEmail;
    }

    function isValidMomentCreate(data) {
      return data.keys().hasAll(['tripId', 'date', 'images', 'note', 'userId', 'userName', 'userEmail', 'createdAt'])
        && data.keys().size() == 8
        && data.tripId is string
        && data.date is string
        && data.images is list
        && data.note is string && data.note.size() <= 2000
        && data.userId is string && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 100
        && data.userEmail is string && data.userEmail.size() <= 100
        && data.createdAt == request.time;
    }

    function isValidMomentUpdate(data) {
      return data.keys().hasAll(['tripId', 'date', 'images', 'note', 'userId', 'userName', 'userEmail', 'createdAt'])
        && data.keys().size() == 8
        && data.tripId == existing().tripId
        && data.date is string
        && data.images is list
        && data.note is string && data.note.size() <= 2000
        && data.userId == existing().userId
        && data.userName == existing().userName
        && data.userEmail == existing().userEmail
        && data.createdAt == existing().createdAt;
    }

    // 4. Collection Rules
    match /trips/{tripId} {
      allow read: if true;
      allow create: if isAuthor() && isValidTripCreate(incoming());
      allow update: if isAuthor() && isOwner(existing().userId) && isValidTripUpdate(incoming());
      allow delete: if isAuthor() && isOwner(existing().userId);
    }

    match /moments/{momentId} {
      allow read: if true;
      allow create: if isAuthor() && isValidMomentCreate(incoming());
      allow update: if isAuthor() && isOwner(existing().userId) && isValidMomentUpdate(incoming());
      allow delete: if isAuthor() && isOwner(existing().userId);
    }
  }
}
