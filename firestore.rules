rules_version = '2';
// Forced update for deployment retry
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 3. Entity Validation
    function isValidTrip(data) {
      return data.keys().hasAll(['name', 'coverImageUrl', 'userId', 'userName', 'userEmail', 'createdAt'])
        && data.keys().size() == 6
        && data.name is string && data.name.size() <= 100
        && data.coverImageUrl is string && data.coverImageUrl.size() <= 1045000
        && data.userId is string && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 100
        && data.userEmail is string && data.userEmail.size() <= 100
        && data.createdAt == request.time;
    }

    function isValidMoment(data) {
      return data.keys().hasAll(['tripId', 'date', 'images', 'note', 'userId', 'userName', 'userEmail', 'createdAt'])
        && data.keys().size() == 8
        && data.tripId is string
        && data.date is string
        && data.images is list
        && data.note is string && data.note.size() <= 2000
        && data.userId is string && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 100
        && data.userEmail is string && data.userEmail.size() <= 100
        && data.createdAt == request.time;
    }

    // 4. Collection Rules
    match /trips/{tripId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidTrip(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidTrip(incoming());
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /moments/{momentId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidMoment(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidMoment(incoming());
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
